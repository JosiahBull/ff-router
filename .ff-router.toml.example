# Copy to ~/.ff-router.toml
#
# `extends`  : optional path (or array of paths) to base config files merged in
#               under this one. Use it to keep shared defaults in one place
#               (e.g. a dotfiles repo) while this file holds per-machine
#               overrides. This file wins over its bases; for the ordered
#               `[[rule]]` list, this file's rules are tried first, then each
#               base in turn. A leading `~/` is expanded; a relative path is
#               resolved against this file's directory. Example:
#                   extends = "~/.dotfiles/.ff-router.toml"
# `debug`    : when true, append one line per opened link to ~/.ff-router.log
#               (the URL, the opening app, and the matched rule). Off by
#               default; the log grows unbounded, so turn it back off when done.
# `default`  : optional. Profile label used when no rule matches. Omit it (the
#               default) to let unmatched links open in whatever profile Firefox
#               opens on its own — your current window, or its own default profile.
# `[profiles]`: label -> Firefox profile directory name (under
#               ~/Library/Application Support/Firefox/Profiles/), or an
#               absolute path.
# `[[rule]]` : ordered override rules. The first matching rule wins. A rule can
#               match on the URL (`globs`), the app that opened the link
#               (`source`), or both — when both are set, both must match.
#               Globs use full Unix-shell syntax: `*` (any run, including `/`),
#               `?` (any single char), `[abc]`/`[a-z]` classes, `[!abc]`
#               negation, and `{a,b}` alternation. Escape a literal
#               metacharacter with `\` — e.g. `\?` to match a real `?` in a
#               query string. The match is anchored (the whole value must match).
#
#               `source` globs are matched against the opening application's
#               bundle id AND its localized name (either matching is enough).
#               Best-effort: links opened without a sender (terminal `open`,
#               Spotlight, some sandboxed apps) have no opener, so `source`
#               rules skip them.

debug = false


[profiles]
work     = "qtIifLeX.Profile 1"        # Firefox "Work" profile
personal = "dhutbqgo.default-release"   # Firefox "Home" profile (Firefox's default)

[[rule]]
profile = "work"
globs = [
    "*://*.atlassian.net/*",
    "*://*.slack.com/*",
    "*://github.com/partly*",
    "*://*.partly.com/*",
]

# Send everything opened from Slack or Microsoft Teams to the work profile,
# whatever the URL. (Matched against the opener's bundle id or app name.)
[[rule]]
profile = "work"
source = [
    "com.tinyspeck.*",   # Slack
    "Microsoft Teams",
]
