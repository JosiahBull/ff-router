# Copy to ~/.ff-router.toml
#
# `default`  : profile label used when no rule matches.
# `[profiles]`: label -> Firefox profile directory name (under
#               ~/Library/Application Support/Firefox/Profiles/), or an
#               absolute path.
# `[[rule]]` : ordered override rules. The first rule with a glob matching the
#               URL wins. Globs use full Unix-shell syntax: `*` (any run,
#               including `/`), `?` (any single char), `[abc]`/`[a-z]` classes,
#               `[!abc]` negation, and `{a,b}` alternation. Escape a literal
#               metacharacter with `\` — e.g. `\?` to match a real `?` in a
#               query string. The match is anchored (the whole URL must match).

default = "personal"

[profiles]
work     = "qtIifLeX.Profile 1"        # Firefox "Work" profile
personal = "dhutbqgo.default-release"   # Firefox "Home" profile

[[rule]]
profile = "work"
globs = [
    "*://*.atlassian.net/*",
    "*://*.slack.com/*",
    "*://github.com/partly*",
    "*://*.partly.com/*",
]
